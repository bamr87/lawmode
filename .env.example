# LawMode.ai Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# =============================================================================
# LLM API Keys (Required - set at least one based on your provider)
# =============================================================================

# OpenAI API Key (required if using OpenAI)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# xAI Grok API Key (required if using xAI Grok)
# Get your key from: https://console.x.ai/
# Note: xAI API keys start with "xai-"
XAI_API_KEY=your-xai-grok-api-key-here
# Alternative: GROK_API_KEY (also supported)
GROK_API_KEY=your-grok-api-key-here

# =============================================================================
# LawMode Configuration (Optional - defaults shown)
# =============================================================================

# LLM Provider: openai or grok
# Default: openai
LAWMODE_LLM_PROVIDER=openai

# LLM Model name (defaults shown for each provider)
# 
# OpenAI Models (when LAWMODE_LLM_PROVIDER=openai):
#   - gpt-4o (default, recommended)
#   - gpt-4-turbo
#   - gpt-4
#   - gpt-3.5-turbo
# 
# xAI Grok Models (when LAWMODE_LLM_PROVIDER=grok):
#   - grok-2-1212 (default, recommended)
#   - grok-3
#   - grok-3-mini
#   - grok-4-0709
#   - grok-4-fast-reasoning
#   - grok-4-fast-non-reasoning
#   - grok-code-fast-1
#   - grok-2-vision-1212
# 
# Default: gpt-4o (for OpenAI) or grok-2-1212 (for Grok)
LAWMODE_LLM_MODEL=gpt-4o

# Alternative: Use a single API key variable (overrides provider-specific keys)
# If set, this will be used regardless of LAWMODE_LLM_PROVIDER
# LAWMODE_LLM_API_KEY=your-universal-api-key-here

# =============================================================================
# Provider-Specific Defaults
# =============================================================================

# To use OpenAI with default model (gpt-4o):
# LAWMODE_LLM_PROVIDER=openai
# LAWMODE_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=your-openai-key

# To use xAI Grok with default model (grok-2-1212):
# LAWMODE_LLM_PROVIDER=grok
# LAWMODE_LLM_MODEL=grok-2-1212
# XAI_API_KEY=your-xai-key

# =============================================================================
# Notes
# =============================================================================
# 
# 1. You only need to set the API key for your chosen provider
# 2. If you set multiple API keys, the one matching LAWMODE_LLM_PROVIDER will be used
# 3. For GitHub Actions, add these as secrets in your repository settings
# 4. For Docker Compose, create a .env file from this template
# 5. For local development, copy this file to .env and fill in your values
# 6. xAI Grok API keys start with "xai-" prefix
# 7. Model defaults are automatically set based on provider if not specified
